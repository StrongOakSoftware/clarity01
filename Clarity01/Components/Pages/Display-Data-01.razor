@page "/display-data-01"
@rendermode InteractiveServer

<h3>Display_Data_01</h3>


@clickedItem["Id"]

<table class="styled-table">
    <thead>
        <tr>
                @foreach (var columnName in columnNames)
                {
                    <th>@columnName</th>
                }
        </tr>
    </thead>
    <tbody>
        @foreach (var row in rowsAsDictionaries)
        {
            <tr @onclick="() => HandleRowClick(row)">
                @foreach (var columnName in columnNames)
                {
                    <td>@row[columnName]</td>
                }
            </tr>
        }
    </tbody>
</table>

